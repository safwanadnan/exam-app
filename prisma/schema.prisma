// Exam Scheduler - Prisma Schema
// Complete port of UniTime's exam timetabling data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           String    @default("MANAGER") // ADMIN, MANAGER, INSTRUCTOR, VIEW_ONLY

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// ACADEMIC STRUCTURE
// ============================================================================

model AcademicSession {
  id          String   @id @default(cuid())
  name        String   // e.g., "Spring 2025"
  year        Int
  term        String   // e.g., "Spring", "Fall", "Summer"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)

  departments  Department[]
  examTypes    ExamType[]
  courses      Course[]
  solverRuns   SolverRun[]
  solverConfigs SolverConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String @id @default(cuid())
  code      String
  name      String
  sessionId String

  session  AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subjects Subject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, sessionId])
}

model Subject {
  id           String @id @default(cuid())
  code         String // e.g., "CS"
  name         String // e.g., "Computer Science"
  departmentId String

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses    Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, departmentId])
}

model Course {
  id          String @id @default(cuid())
  courseNumber String // e.g., "101"
  title       String // e.g., "Intro to CS"
  subjectId   String
  sessionId   String

  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  session  AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseNumber, subjectId, sessionId])
}

model Section {
  id         String @id @default(cuid())
  sectionNumber String // e.g., "001"
  courseId    String

  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments StudentEnrollment[]
  examOwners  ExamOwner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionNumber, courseId])
}

// ============================================================================
// ROOM MANAGEMENT (maps to ExamRoom in CPSolver)
// ============================================================================

model Building {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  coordX    Float? // X coordinate for distance calculation
  coordY    Float? // Y coordinate for distance calculation

  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id           String  @id @default(cuid())
  name         String
  buildingId   String
  capacity     Int     // Normal seating capacity
  altCapacity  Int?    // Alternate (exam) seating capacity
  coordX       Float?  // Override coordinates
  coordY       Float?

  building       Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  features       RoomFeatureAssignment[]
  availability   RoomPeriodAvailability[]
  preferences    RoomPreference[]
  examAssignments ExamAssignmentRoom[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, buildingId])
}

model RoomFeature {
  id    String @id @default(cuid())
  code  String @unique
  name  String
  type  String @default("BOOLEAN") // BOOLEAN, NUMERIC

  assignments         RoomFeatureAssignment[]
  featurePreferences  RoomFeaturePreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomFeatureAssignment {
  id        String @id @default(cuid())
  roomId    String
  featureId String

  room    Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  feature RoomFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([roomId, featureId])
}

// Room availability per exam period
model RoomPeriodAvailability {
  id        String  @id @default(cuid())
  roomId    String
  periodId  String
  available Boolean @default(true)
  penalty   Int     @default(0) // 0=available, -1=prohibited, >0=discouraged with penalty

  room   Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  period ExamPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([roomId, periodId])
}

// ============================================================================
// EXAM ENTITIES (maps to Exam, ExamPeriod in CPSolver)
// ============================================================================

model ExamType {
  id        String @id @default(cuid())
  name      String // "Midterm", "Final"
  code      String
  sessionId String

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exams   Exam[]
  periods ExamPeriod[]

  @@unique([code, sessionId])
}

// Maps to ExamPeriod in CPSolver
model ExamPeriod {
  id         String   @id @default(cuid())
  examTypeId String
  date       DateTime
  startTime  String   // "08:00"
  endTime    String   // "10:00"
  length     Int      // Duration in minutes
  day        Int      // Day index (0-based)
  timeIndex  Int      // Time slot index within day
  penalty    Int      @default(0) // Period penalty weight
  eventId    String?  // Optional event reference

  examType          ExamType                @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  roomAvailability  RoomPeriodAvailability[]
  periodPreferences PeriodPreference[]
  examAssignments   ExamAssignment[]

  // Linked list for traversal (next/prev)
  prevPeriodId String? @unique
  prevPeriod   ExamPeriod? @relation("PeriodChain", fields: [prevPeriodId], references: [id])
  nextPeriod   ExamPeriod? @relation("PeriodChain")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, startTime, examTypeId])
}

// Maps to Exam in CPSolver - the VARIABLE in the constraint problem
model Exam {
  id           String  @id @default(cuid())
  name         String?
  examTypeId   String
  length       Int     // Exam duration in minutes
  size         Int     @default(0) // Number of students (computed or manual)
  minSize      Int     @default(0) // Minimum required size
  sizeOverride Int?    // Manual size override
  maxRooms     Int     @default(4) // Max rooms for splitting (-1 = unlimited)
  altSeating   Boolean @default(false) // Requires alternate seating layout
  printOffset  Int?    // Print offset in minutes for reporting
  avgPeriod    Int     @default(0) // Average period index (for rotation penalty)

  examType            ExamType               @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  owners              ExamOwner[]
  studentEnrollments  StudentEnrollment[]
  instructorAssignments InstructorAssignment[]
  periodPreferences   PeriodPreference[]
  roomPreferences     RoomPreference[]
  featurePreferences  RoomFeaturePreference[]
  distributionConstraintsA DistributionConstraint[] @relation("DistConsA")
  distributionConstraintsB DistributionConstraint[] @relation("DistConsB")
  assignment          ExamAssignment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Maps to ExamOwner - which course/section owns this exam
model ExamOwner {
  id        String @id @default(cuid())
  examId    String
  sectionId String

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([examId, sectionId])
}

// ============================================================================
// STUDENTS & INSTRUCTORS (maps to ExamStudent, ExamInstructor in CPSolver)
// ============================================================================

model Student {
  id         String @id @default(cuid())
  externalId String @unique // University student ID
  name       String

  enrollments    StudentEnrollment[]
  unavailability StudentUnavailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentEnrollment {
  id        String @id @default(cuid())
  studentId String
  sectionId String
  examId    String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model StudentUnavailability {
  id        String @id @default(cuid())
  studentId String
  periodId  String // ExamPeriod they are unavailable

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, periodId])
}

model Instructor {
  id         String @id @default(cuid())
  externalId String @unique
  name       String

  assignments    InstructorAssignment[]
  unavailability InstructorUnavailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InstructorAssignment {
  id           String @id @default(cuid())
  instructorId String
  examId       String

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  exam       Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([instructorId, examId])
}

model InstructorUnavailability {
  id           String @id @default(cuid())
  instructorId String
  periodId     String

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, periodId])
}

// ============================================================================
// CONSTRAINTS & PREFERENCES (maps to ExamDistributionConstraint in CPSolver)
// ============================================================================

// Binary distribution constraint between two exams
model DistributionConstraint {
  id       String  @id @default(cuid())
  type     String  // SAME_ROOM, DIFF_ROOM, SAME_PERIOD, DIFF_PERIOD, PRECEDENCE, SAME_DAY, OVERLAP, SAME_STUDENTS, DIFF_STUDENTS
  hard     Boolean @default(false) // true = required, false = preferred
  weight   Int     @default(1) // Weight for soft constraints
  examAId  String
  examBId  String

  examA Exam @relation("DistConsA", fields: [examAId], references: [id], onDelete: Cascade)
  examB Exam @relation("DistConsB", fields: [examBId], references: [id], onDelete: Cascade)

  @@unique([type, examAId, examBId])
}

// Period preference for an exam
model PeriodPreference {
  id       String @id @default(cuid())
  examId   String
  periodId String
  level    String // REQUIRED, STRONGLY_PREFERRED, PREFERRED, NEUTRAL, DISCOURAGED, STRONGLY_DISCOURAGED, PROHIBITED

  exam   Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  period ExamPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([examId, periodId])
}

// Room preference for an exam
model RoomPreference {
  id     String @id @default(cuid())
  examId String
  roomId String
  level  String // REQUIRED, STRONGLY_PREFERRED, PREFERRED, NEUTRAL, DISCOURAGED, STRONGLY_DISCOURAGED, PROHIBITED

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([examId, roomId])
}

// Room feature preference for an exam
model RoomFeaturePreference {
  id        String @id @default(cuid())
  examId    String
  featureId String
  level     String // REQUIRED, PREFERRED

  exam    Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  feature RoomFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([examId, featureId])
}

// ============================================================================
// SOLVER OUTPUT (maps to ExamPlacement in CPSolver)
// ============================================================================

// The solver's assignment: exam → period + rooms
model ExamAssignment {
  id       String @id @default(cuid())
  examId   String @unique // One assignment per exam
  periodId String
  runId    String?

  exam   Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  period ExamPeriod        @relation(fields: [periodId], references: [id], onDelete: Cascade)
  rooms  ExamAssignmentRoom[]
  run    SolverRun?        @relation(fields: [runId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Junction table: assignment → rooms (an exam can be split across rooms)
model ExamAssignmentRoom {
  id           String @id @default(cuid())
  assignmentId String
  roomId       String

  assignment ExamAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  room       Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, roomId])
}

// ============================================================================
// SOLVER CONFIGURATION & RUNS
// ============================================================================

model SolverConfig {
  id        String @id @default(cuid())
  name      String
  sessionId String
  isDefault Boolean @default(false)

  // Weight parameters (maps to CPSolver DataProperties)
  directConflictWeight       Float @default(1000.0)
  moreThan2ADayWeight        Float @default(100.0)
  backToBackConflictWeight   Float @default(10.0)
  distBackToBackConflictWeight Float @default(25.0)
  backToBackDistance         Float @default(67.0) // meters
  isDayBreakBackToBack       Boolean @default(false)
  periodPenaltyWeight        Float @default(1.0)
  periodIndexWeight          Float @default(0.0000001)
  periodSizeWeight           Float @default(0.0)
  periodSizeNorm             Float @default(0.0)
  roomSizePenaltyWeight      Float @default(0.001)
  roomSplitPenaltyWeight     Float @default(10.0)
  roomSplitDistanceWeight    Float @default(0.01)
  roomPenaltyWeight          Float @default(1.0)
  distributionWeight         Float @default(1.0)
  perturbationWeight         Float @default(0.01)
  roomPerturbationWeight     Float @default(0.01)
  largeExamPenaltyWeight     Float @default(1.0)
  largeExamSize              Float @default(0.0)
  rotationWeight             Float @default(0.001)

  // Instructor weights
  instructorDirectConflictWeight     Float @default(1000.0)
  instructorMoreThan2ADayWeight      Float @default(100.0)
  instructorBackToBackConflictWeight Float @default(10.0)
  instructorDistBackToBackWeight     Float @default(25.0)

  // Solver parameters
  maxRooms             Int    @default(4)
  timeout              Int    @default(600) // seconds
  useGreatDeluge       Boolean @default(false)
  useColoringConstruction Boolean @default(false)
  checkPeriodOverlaps  Boolean @default(false)

  // Simulated Annealing parameters
  saInitialTemperature    Float @default(1.5)
  saCoolingRate           Float @default(0.95)
  saReheatRate            Float @default(-1.0)
  saReheatLength          Float @default(7.0)
  saRestoreBestLength     Float @default(-1.0)

  // Hill Climbing parameters
  hcMaxIdleIterations     Int @default(25000)

  // Great Deluge parameters
  gdUpperBoundRate        Float @default(0.999999)
  gdCoolRate              Float @default(0.9999995)

  session    AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  solverRuns SolverRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SolverRun {
  id          String   @id @default(cuid())
  sessionId   String
  configId    String
  status      String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, STOPPED
  startedAt   DateTime?
  completedAt DateTime?

  // Results
  totalExams          Int?
  assignedExams       Int?
  directConflicts     Int?
  backToBackConflicts Int?
  moreThan2ADay       Int?
  totalPenalty        Float?
  bestObjective       Float?
  iterations          Int?
  phase               String? // Current phase name
  log                 String? // JSON log of progress snapshots

  session     AcademicSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  config      SolverConfig     @relation(fields: [configId], references: [id], onDelete: Cascade)
  assignments ExamAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
